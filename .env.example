# Copy to .env and fill in. Only fill the platforms you use; each tool reports a
# clear setup error until its own credentials are present.

# --- Google Ads (keyword research + reporting + management) ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=   # manager (MCC) id, digits only, no dashes
GOOGLE_ADS_CUSTOMER_ID=         # the account to query, digits only, no dashes

# --- Meta Ads (reporting + management) ---
META_ACCESS_TOKEN=              # Marketing API access token with ads_read / ads_management

# --- GA4 (analytics) ---
GOOGLE_APPLICATION_CREDENTIALS= # absolute path to a service-account .json with
                                # Analytics Viewer access on the GA4 property
